        { "action": "clickBest", "candidates": ["[data-filter='favorites']", "li:has-text('Favorites')", "li:has-text('Избранное')"] },
        { "action": "wait", "ms": 600 }
      ],
      "create_post": [
        { "action": "clickBest", "candidates": [".feed-add-post-form-wrap", ".livefeed-post-text", ".feed-add-post-form textarea"] },
        { "action": "wait", "ms": 500 }
      ],
      "more_menu": [
        { "action": "clickBest", "candidates": ["[data-action='more']", "button:has-text('More')", ".feed-more-btn"] },
        { "action": "wait", "ms": 500 }
      ]
    }
  },

