  "Tariff_Widget": {
    "urlPath": "/",
    "waitFor": "body",
    "steps": {
      "default": [
        { "action": "waitTimeout", "ms": 2000 },
        { "action": "clickFirst", "selectors": [
          ".payroll-widget",
          "[class*='tariff-widget']",
          "a[href*='/settings/license/']",
          ".b24-tariff-widget",
          ".feed-desktop__plan",
          "[class*='tariff']"
        ]},
        { "action": "waitTimeout", "ms": 1500 }
      ],
      "limits": [
        { "action": "waitTimeout", "ms": 2000 },
        { "action": "clickFirst", "selectors": ["[class*='tariff-widget']", "a[href*='/settings/license/']", "[class*='tariff']"] },
        { "action": "waitTimeout", "ms": 1500 },
        { "action": "clickFirst", "selectors": ["button:has-text('Open limits')", "a:has-text('Limits')", "[class*='limits']"] },
        { "action": "waitTimeout", "ms": 800 }
      ]
    }
  },

