{
  "Feed": {
    "urlPath": "/stream/",
    "waitFor": ".feed-add-post-form-wrap, .feed-post-list",
    "steps": {
      "default": [],
      "pinned_messages": [
        { "action": "waitForSelector", "selector": ".feed-post-pin-container, .feed-post-pin" }
      ],
      "favorites_filter": [
        { "action": "clickFirst", "selectors": [".feed-filter-btn", "[data-action='filter']", ".feed-toolbar__filter"] },
        { "action": "waitTimeout", "ms": 500 },
        { "action": "clickFirst", "selectors": ["[data-filter='favorites']", "li:has-text('Favorites')", "li:has-text('Избранное')"] },
        { "action": "waitTimeout", "ms": 800 }
      ],
      "create_post": [
        { "action": "clickFirst", "selectors": [".feed-add-post-form-wrap", ".livefeed-post-text", ".feed-add-post-form textarea"] },
        { "action": "waitTimeout", "ms": 500 }
      ],
      "more_menu": [
        { "action": "clickFirst", "selectors": ["[data-action='more']", "button:has-text('More')", ".feed-more-btn"] },
        { "action": "waitTimeout", "ms": 500 }
      ]
    }
  },

  "CRM_Deals": {
    "urlPath": "/crm/deal/",
    "waitFor": ".crm-entity-list-container, .crm-kanban, .ui-grid",
    "steps": {
      "default": [],
      "kanban_view": [
        { "action": "clickFirst", "selectors": ["[data-view='kanban']", ".crm-view-switcher-kanban", "[data-id='kanban']", "button[title*='Kanban' i]"] },
        { "action": "waitTimeout", "ms": 1000 }
      ],
      "list_view": [
        { "action": "clickFirst", "selectors": ["[data-view='list']", ".crm-view-switcher-list", "[data-id='list']", "button[title*='List' i]"] },
        { "action": "waitTimeout", "ms": 1000 }
      ],
      "create_deal": [
        { "action": "clickFirst", "selectors": [".crm-btn-add", "[data-action='add']", "button.ui-btn-success", "button:has-text('Create')"] },
        { "action": "waitTimeout", "ms": 1000 }
      ],
      "settings": [
        { "action": "clickFirst", "selectors": [".crm-btn-settings", "[data-action='settings']", "button[title*='Settings' i]"] },
        { "action": "waitTimeout", "ms": 500 }
      ]
    }
  },

  "CRM_Leads": {
